# Environment Configuration Example

# Application Settings
APP_ENV=development
PROJECT_NAME="Web Assistant"
VERSION=1.0.0
DESCRIPTION="A production-ready FastAPI template with LangGraph and Langfuse integration"
DEBUG=true

# API Settings
API_V1_STR=/api/v1

# CORS Settings
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:8000"

# Langfuse Settings
LANGFUSE_PUBLIC_KEY="your-langfuse-public-key"
LANGFUSE_SECRET_KEY="your-langfuse-secret-key"
LANGFUSE_HOST=https://cloud.langfuse.com

# LLM Settings
OPENAI_API_KEY="your-llm-api-key" # e.g. OpenAI API key
DEFAULT_LLM_MODEL=gpt-5-mini
DEFAULT_LLM_TEMPERATURE=0.2
MAX_TOKENS=2000
MAX_LLM_CALL_RETRIES=3

# Long-Term Memory Settings
LONG_TERM_MEMORY_MODEL=gpt-5-nano
LONG_TERM_MEMORY_EMBEDDER_MODEL=text-embedding-3-small
LONG_TERM_MEMORY_COLLECTION_NAME=longterm_memory

# JWT Settings
JWT_SECRET_KEY="your-jwt-secret-key"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# Database Settings
POSTGRES_HOST=db
POSTGRES_DB=mydb
POSTGRES_USER=myuser
POSTGRES_PORT=5432
POSTGRES_PASSWORD=mypassword
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# Rate Limiting Settings
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_NAVER_BLOG_PREVIEW="20 per minute"
RATE_LIMIT_REGISTER="10 per hour"
RATE_LIMIT_LOGIN="100 per minute"
RATE_LIMIT_ROOT="10 per minute"
RATE_LIMIT_HEALTH="20 per minute"

# Evaluation Settings
EVALUATION_LLM=gpt-5
EVALUATION_BASE_URL=https://api.openai.com/v1
EVALUATION_API_KEY=""
EVALUATION_SLEEP_TIME=10

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
